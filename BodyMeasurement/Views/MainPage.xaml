<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:BodyMeasurement.ViewModels"
             xmlns:resources="clr-namespace:BodyMeasurement.Resources.Strings"
             x:Class="BodyMeasurement.Views.MainPage"
             x:DataType="viewModels:MainViewModel"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Custom Header -->
        <Border Grid.Row="0"
                Padding="16,12"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Left: Logo glyph + App title -->
                <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                    <Label Text="⚖"
                           FontSize="26"
                           TextColor="#8CB43E"
                           VerticalOptions="Center" />
                    <Label Text="LemoWeight"
                           FontSize="20"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Right: Person icon + Gear icon, both navigate to Settings -->
                <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <ImageButton Command="{Binding NavigateToSettingsCommand}"
                                 Padding="4">
                        <ImageButton.Source>
                            <FontImageSource FontFamily="MaterialIcons"
                                            Glyph="&#xE7FD;"
                                            Size="26"
                                            Color="#8CB43E" />
                        </ImageButton.Source>
                    </ImageButton>
                    <ImageButton Command="{Binding NavigateToSettingsCommand}"
                                 Padding="4">
                        <ImageButton.Source>
                            <FontImageSource FontFamily="MaterialIcons"
                                            Glyph="&#xE8B8;"
                                            Size="26"
                                            Color="#8CB43E" />
                        </ImageButton.Source>
                    </ImageButton>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Scrollable content area -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- Green Profile Banner -->
                <Border BackgroundColor="#8CB43E"
                        Padding="20,24"
                        StrokeThickness="0">
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">

                        <!-- Circular border containing app logo -->
                        <Border WidthRequest="80"
                                HeightRequest="80"
                                BackgroundColor="White"
                                HorizontalOptions="Center"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <Ellipse />
                            </Border.StrokeShape>
                            <Label Text="⚖"
                                   FontSize="40"
                                   TextColor="#8CB43E"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- User name label -->
                        <Label Text="{Binding UserName}"
                               TextColor="White"
                               FontSize="20"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Motivational Text Section -->
                <VerticalStackLayout Padding="20,16" Spacing="4">
                    <Label Text="{Binding MotivationalMessage}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                    <Label Text="{x:Static resources:Strings.MotivationalKeepGoing}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Progress Bar Section -->
                <Border Margin="16,0,16,16"
                        Padding="16"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                        StrokeThickness="1">
                    <VerticalStackLayout Spacing="8">

                        <!-- Start / Goal top labels -->
                        <Grid ColumnDefinitions="*,*">
                            <Label Grid.Column="0"
                                   Text="{x:Static resources:Strings.StartLabel}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Grid.Column="1"
                                   Text="{x:Static resources:Strings.GoalLabel}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"
                                   HorizontalOptions="End" />
                        </Grid>

                        <!-- Gradient bar with proportional marker -->
                        <AbsoluteLayout HeightRequest="40">

                            <!-- Red → Yellow → Green horizontal gradient track -->
                            <BoxView AbsoluteLayout.LayoutBounds="0,16,1,8"
                                     AbsoluteLayout.LayoutFlags="WidthProportional">
                                <BoxView.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#E53935" Offset="0" />
                                        <GradientStop Color="#FDD835" Offset="0.5" />
                                        <GradientStop Color="#43A047" Offset="1" />
                                    </LinearGradientBrush>
                                </BoxView.Background>
                            </BoxView>

                            <!-- Vertical marker at proportional X position -->
                            <BoxView AbsoluteLayout.LayoutFlags="XProportional"
                                     AbsoluteLayout.LayoutBounds="{Binding ProgressMarkerBounds}"
                                     BackgroundColor="White"
                                     WidthRequest="4"
                                     HeightRequest="40" />
                        </AbsoluteLayout>

                        <!-- Start / Goal weight values -->
                        <Grid ColumnDefinitions="*,*">
                            <Label Grid.Column="0"
                                   Text="{Binding StartWeightDisplay}"
                                   FontSize="12"
                                   FontAttributes="Bold" />
                            <Label Grid.Column="1"
                                   Text="{Binding GoalWeightDisplay}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   HorizontalOptions="End" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Measurement Cards -->
                <VerticalStackLayout Padding="16,0,16,16" Spacing="8">

                    <!-- Weight Card -->
                    <Border Padding="16"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                            StrokeThickness="1">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Label Grid.Column="0"
                                   Text="{x:Static resources:Strings.WeightLabel}"
                                   FontSize="14"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding WeightLostDisplay}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   Margin="0,0,8,0" />
                            <Label Grid.Column="2"
                                   Text="&#xE5CF;"
                                   FontFamily="MaterialIcons"
                                   FontSize="20"
                                   TextColor="#8CB43E"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Visceral Fat Card -->
                    <Border Padding="16"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                            StrokeThickness="1">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Label Grid.Column="0"
                                   Text="{x:Static resources:Strings.VisceralFatLabel}"
                                   FontSize="14"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding VisceralFatDisplay}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   Margin="0,0,8,0" />
                            <Label Grid.Column="2"
                                   Text="&#xE5CF;"
                                   FontFamily="MaterialIcons"
                                   FontSize="20"
                                   TextColor="#8CB43E"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Body Water Card -->
                    <Border Padding="16"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                            StrokeThickness="1">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Label Grid.Column="0"
                                   Text="{x:Static resources:Strings.WaterInBodyLabel}"
                                   FontSize="14"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding WaterDisplay}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   Margin="0,0,8,0" />
                            <Label Grid.Column="2"
                                   Text="&#xE5CF;"
                                   FontFamily="MaterialIcons"
                                   FontSize="20"
                                   TextColor="#8CB43E"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Muscle Card -->
                    <Border Padding="16"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                            StrokeThickness="1">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Label Grid.Column="0"
                                   Text="{x:Static resources:Strings.MuscleLabel}"
                                   FontSize="14"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding MuscleDisplay}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   Margin="0,0,8,0" />
                            <Label Grid.Column="2"
                                   Text="&#xE5CF;"
                                   FontFamily="MaterialIcons"
                                   FontSize="20"
                                   TextColor="#8CB43E"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- BMI Card -->
                    <Border Padding="16"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                            StrokeThickness="1">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Label Grid.Column="0"
                                   Text="{x:Static resources:Strings.BmiLabel}"
                                   FontSize="14"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding BmiDisplay}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   Margin="0,0,8,0" />
                            <Label Grid.Column="2"
                                   Text="&#xE5CF;"
                                   FontFamily="MaterialIcons"
                                   FontSize="20"
                                   TextColor="#8CB43E"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- Bottom padding so FAB does not overlap last card -->
                <BoxView HeightRequest="80" Color="Transparent" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Floating Action Button — green brand color -->
        <Button Grid.Row="1"
                Text="+"
                FontSize="28"
                Padding="0"
                Command="{Binding NavigateToAddWeightCommand}"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                BackgroundColor="#8CB43E"
                TextColor="White"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,20"
                Shadow="{Shadow Brush=Black, Opacity=0.3, Radius=8, Offset='0,4'}">
        </Button>

    </Grid>

</ContentPage>
